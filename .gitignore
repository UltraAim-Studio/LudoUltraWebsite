node_modules/
package-lock.json
npm-debug.log
yarn-error.log
.npm
dist/
build/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv
.env
pip-log.txt
pip-delete-this-directory.txt

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
